            "path": ["exchange", "exchange-coin", "base-symbol"]
          },
          "description": "获取交易对配置中的基币列表（如 USDT/BTC/ETH 等）。"
        }
      },
      {
        "name": "添加自选 /favor/add",
        "request": {
          "method": "POST",
          "header": [
            {
              "key": "Content-Type",
              "name": "Content-Type",
              "value": "application/x-www-form-urlencoded",
              "type": "text"
            }
          ],
          "url": {
            "raw": "http://127.0.0.1:6003/exchange/favor/add",
            "protocol": "http",
            "host": ["127", "0", "0", "1"],
            "port": "6003",
            "path": ["exchange", "favor", "add"]
          },
          "body": {
            "mode": "urlencoded",
            "urlencoded": [
              { "key": "symbol", "value": "BTC/USDT", "type": "text" }
            ]
          },
          "description": "需要 Session，将指定交易对加入当前用户自选。"
        }
      },
      {
        "name": "查询自选列表 /favor/find",
        "request": {
          "method": "GET",
          "url": {
            "raw": "http://127.0.0.1:6003/exchange/favor/find",
            "protocol": "http",
            "host": ["127", "0", "0", "1"],
            "port": "6003",
            "path": ["exchange", "favor", "find"]
          },
          "description": "需要 Session，查询当前用户所有自选交易对。"
        }
      },
      {
        "name": "删除自选 /favor/delete",
        "request": {
          "method": "POST",
          "header": [
            {
              "key": "Content-Type",
              "name": "Content-Type",
              "value": "application/x-www-form-urlencoded",
              "type": "text"
            }
          ],
          "url": {
            "raw": "http://127.0.0.1:6003/exchange/favor/delete",
            "protocol": "http",
            "host": ["127", "0", "0", "1"],
            "port": "6003",
            "path": ["exchange", "favor", "delete"]
          },
          "body": {
            "mode": "urlencoded",
            "urlencoded": [
              { "key": "symbol", "value": "BTC/USDT", "type": "text" }
            ]
          },
          "description": "需要 Session，从当前用户自选中删除指定交易对。"
        }
      }
    ],
    "variable": [
      {
        "key": "orderId",
        "value": "REPLACE_WITH_ORDER_ID",
