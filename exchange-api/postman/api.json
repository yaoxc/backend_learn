          "description": "行情机器人查询指定 uid 的当前挂单列表。"
        }
      },
      {
        "name": "机器人撤单 /order/mockcancelydhdnskd",
        "request": {
          "method": "POST",
          "header": [
            {
              "key": "Content-Type",
              "name": "Content-Type",
              "value": "application/x-www-form-urlencoded",
              "type": "text"
            }
          ],
          "url": {
            "raw": "http://127.0.0.1:6003/exchange/order/mockcancelydhdnskd",
            "protocol": "http",
            "host": ["127", "0", "0", "1"],
            "port": "6003",
            "path": ["exchange", "order", "mockcancelydhdnskd"]
          },
          "body": {
            "mode": "urlencoded",
            "urlencoded": [
              { "key": "uid", "value": "1", "type": "text" },
              { "key": "sign", "value": "987654321asdf", "type": "text" },
              { "key": "orderId", "value": "{{orderId}}", "type": "text" }
            ]
          },
          "description": "行情机器人撤单，内部仍通过 outbox + Kafka 转发到撮合。"
        }
      },
      {
        "name": "获取基币列表 /exchange-coin/base-symbol",
        "request": {
